# =============================================================================
# Suly Envios — environment variables
# Copy to .env for local dev. Never commit .env.
# Production: set in Render/Railway dashboard (see render.yaml / railway.toml).
# =============================================================================

# --- Local MySQL (omit DATABASE_URL to use these) ---
DB_HOST=localhost
DB_NAME=suly_envios
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- Production database (Supabase Postgres pooler) ---
# Supabase Dashboard → Project Settings → Database → Connection string (URI, port 6543)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- Supabase (project: suly-envios) ---
SUPABASE_URL=https://ccmkdeizjdshdlpbotpt.supabase.co
SUPABASE_ANON_KEY=your-anon-key-from-dashboard
# Server-side only — required for Phase 3 Storage (private bucket uploads + api/files proxy).
# Supabase Dashboard → Project Settings → API → service_role (secret). Never expose to browser or commit.
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini (server-side document parsing only — never expose to browser) ---
# Google AI Studio → API key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- App ---
APP_NAME=Suly Envios
APP_URL=http://localhost:8080
# Production example: APP_URL=https://envios.yourdomain.com

# Session signing / hardening (generate: openssl rand -hex 32)
SESSION_SECRET=

MAX_UPLOAD_SIZE=10485760
SESSION_LIFETIME=86400

# --- Platform (set automatically on Render/Railway) ---
# PORT=8080

# --- Render MCP (Cursor — not used by the PHP app) ---
# Render uses API keys only (no OAuth). Cursor login/logout buttons do not apply.
# One-time setup:
#   bash scripts/setup-render-mcp.sh
# Logout / revoke local key:
#   bash scripts/render-mcp-logout.sh
# Key file: ~/.cursor/secrets/render.env (gitignored globally, never commit)
