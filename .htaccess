RewriteEngine On

# API: never execute api/*.php directly (bootstrap lives in index.php)
RewriteRule ^api/.+\.php$ index.php [QSA,L]

# Admin-only HTML shells must go through index.php (auth + role guards)
RewriteRule ^pages/(stores|analytics|import|reports-center)\.html$ index.php [QSA,L]

# If the request is for an existing file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything else through index.php
RewriteRule ^(.*)$ index.php [QSA,L]
